---
import Container from "./Container.astro";
import { siteConfig, withBase } from "../data/site";

const navigation = siteConfig.footerNavigation.map((item) => ({
  ...item,
  href: withBase(item.href),
}));
---

<footer class="border-t border-stone-200 bg-white">
  <Container class="py-8 sm:py-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="max-w-2xl space-y-2">
        <p class="font-serif text-xl tracking-tight text-stone-950">{siteConfig.name}</p>
        <p class="text-sm leading-6 text-stone-600">{siteConfig.thesis}</p>
      </div>

      <nav aria-label="Footer">
        <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm text-stone-600">
          {navigation.map((item) => (
            <li>
              <a class="transition-colors duration-150 hover:text-stone-950" href={item.href}>
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </Container>
</footer>

---
import Container from "./Container.astro";
import { siteConfig, withBase } from "../data/site";

const navigation = siteConfig.footerNavigation.map((item) => ({
  ...item,
  href: withBase(item.href),
}));
---

<footer class="border-t border-black/5 bg-transparent">
  <Container class="pb-12 pt-8 sm:pb-14 sm:pt-10">
    <div class="surface-panel-soft px-7 py-8 sm:px-10 sm:py-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
        <div class="max-w-2xl space-y-4">
          <p class="eyebrow-label">Real PM Jobs</p>
          <h2 class="text-3xl font-semibold leading-[0.96] tracking-[-0.055em] text-zinc-950 sm:text-4xl">
            A narrower board for higher-scope product roles.
          </h2>
          <p class="body-copy max-w-xl">{siteConfig.thesis}</p>
        </div>

        <div class="space-y-4">
          <nav aria-label="Footer">
            <ul class="flex flex-wrap gap-2">
              {navigation.map((item) => (
                <li>
                  <a class="nav-link" href={item.href}>{item.label}</a>
                </li>
              ))}
            </ul>
          </nav>

          <p class="text-sm leading-6 text-zinc-500">
            Curated for mandate and role scope, not title inflation.
          </p>
        </div>
      </div>
    </div>
  </Container>
</footer>

---
import type { CollectionEntry } from "astro:content";

type JobEntry = CollectionEntry<"jobs">;

interface Props {
  job: JobEntry;
}

const { job } = Astro.props;

const evidenceItems = [
  {
    label: "Outcomes",
    value: job.data.outcomesOwned[0],
  },
  {
    label: "Decision rights",
    value: job.data.decisionRights[0],
  },
  {
    label: "Discovery",
    value: job.data.discoveryModel,
  },
  {
    label: "Team topology",
    value: job.data.teamTopology,
  },
];
---

<div class="grid gap-3 sm:grid-cols-2">
  {evidenceItems.map((item) => (
    <div class="surface-hairline px-4 py-4">
      <div class="space-y-2">
        <p class="eyebrow-label !tracking-[0.22em]">{item.label}</p>
        <p class="text-sm leading-6 text-zinc-700">{item.value}</p>
      </div>
    </div>
  ))}
</div>

---
import { withBase } from "../data/site";

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  href?: string;
  ctaLabel?: string;
}

const { eyebrow, title, description, href, ctaLabel } = Astro.props;
const isExternal = href?.startsWith("http://") || href?.startsWith("https://") || href?.startsWith("mailto:");
const resolvedHref = href ? (isExternal ? href : withBase(href)) : undefined;
---

<aside class="panel-dark px-6 py-7 sm:px-8 sm:py-9">
  <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
    <div class="max-w-3xl space-y-4">
      {eyebrow && <p class="eyebrow-label">{eyebrow}</p>}
      <h2 class="text-3xl font-semibold leading-[0.93] tracking-[-0.08em] text-white sm:text-4xl">
        {title}
      </h2>
      <p class="max-w-2xl text-base leading-7 text-zinc-300">{description}</p>
    </div>

    {resolvedHref && ctaLabel && (
      <a class="button-dark px-5 py-3" href={resolvedHref}>
        {ctaLabel}
      </a>
    )}
  </div>
</aside>

---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  headingTag?: string;
}

const { eyebrow, title, description, headingTag: HeadingTag = "h1" } = Astro.props;
---

<section class="space-y-5">
  {eyebrow && (
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500">{eyebrow}</p>
  )}

  <div class="max-w-3xl space-y-4">
    <HeadingTag class="font-serif text-4xl tracking-tight text-stone-950 sm:text-5xl">
      {title}
    </HeadingTag>

    {description && <p class="text-lg leading-8 text-stone-700">{description}</p>}
  </div>

  <slot />
</section>

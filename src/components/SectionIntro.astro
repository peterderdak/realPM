---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  headingTag?: string;
}

const { eyebrow, title, description, headingTag: HeadingTag = "h1" } = Astro.props;
---

<section class="space-y-5">
  {eyebrow && <p class="eyebrow-label">{eyebrow}</p>}

  <div class="max-w-3xl space-y-4">
    <HeadingTag class="section-title">{title}</HeadingTag>

    {description && <p class="lede-text max-w-2xl">{description}</p>}
  </div>

  <slot />
</section>

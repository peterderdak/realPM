---
import MainLayout from "../layouts/MainLayout.astro";
import CtaBlock from "../components/CtaBlock.astro";
import Pill from "../components/Pill.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { formatJobFilterValue, getFeaturedJobs, getJobDetailPath } from "../data/jobs";
import { siteConfig, withBase } from "../data/site";

const featuredJobs = (await getFeaturedJobs()).slice(0, 3);
const jobsHref = withBase("/jobs");
const methodologyHref = withBase("/methodology");
const employersHref = withBase("/for-employers");

const heroSignals = [
  {
    title: "Outcome ownership",
    body: "Someone is clearly accountable for a product result, not just the movement of work.",
  },
  {
    title: "Decision rights",
    body: "The PM can make tradeoffs, set priorities, and define what the team should not do.",
  },
  {
    title: "Discovery capacity",
    body: "The role has room to learn through evidence, not just execute an inherited plan.",
  },
];

const exclusions = [
  "Delivery-buffer roles that mainly absorb pressure and keep work flowing.",
  "Backlog-admin roles centered on tickets, rituals, and status maintenance.",
  "Stakeholder-proxy roles with title-level expectations but no actual authority.",
  "Feature-team coordinator roles that optimize process while avoiding product judgment.",
];
---

<MainLayout
  title={siteConfig.name}
  description="Most PM jobs are not actually PM jobs. Real PM Jobs is a curated board for roles with real outcome ownership, decision rights, and discovery capacity."
>
  <div class="space-y-24 sm:space-y-28">
    <section class="grid gap-8 lg:grid-cols-[minmax(0,1.15fr)_minmax(20rem,0.85fr)] lg:items-stretch">
      <div class="surface-panel-soft px-6 py-8 sm:px-8 sm:py-10 lg:px-10 lg:py-12">
        <div class="max-w-4xl space-y-8">
          <div class="flex flex-wrap gap-2">
            <Pill label="Editorial job board" />
            <Pill label="Manual review" />
            <Pill label="Static and curated" />
          </div>

          <div class="space-y-5">
            <p class="eyebrow-label">A narrower board for product roles with actual mandate</p>
            <h1 class="display-title max-w-4xl">Most PM jobs aren&apos;t actually PM jobs.</h1>
            <p class="lede-text max-w-3xl">
              Real PM Jobs filters for outcome ownership, decision rights, and discovery capacity.
              If the mandate is missing, the title does not rescue the role.
            </p>
            <p class="body-copy max-w-2xl">
              This is not a general-purpose PM listing site. It is a stricter publication for
              product roles that still expect judgment, prioritization, and learning.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a class="button-primary" href={jobsHref}>Browse Jobs</a>
            <a class="button-secondary" href={methodologyHref}>See Methodology</a>
          </div>

          <div class="grid gap-3 sm:grid-cols-3">
            <div class="surface-hairline px-4 py-4">
              <p class="eyebrow-label !tracking-[0.22em]">Board standard</p>
              <p class="mt-2 text-sm leading-6 text-zinc-700">Scope first. Title second.</p>
            </div>
            <div class="surface-hairline px-4 py-4">
              <p class="eyebrow-label !tracking-[0.22em]">Publishing bar</p>
              <p class="mt-2 text-sm leading-6 text-zinc-700">Fewer jobs, clearer mandate.</p>
            </div>
            <div class="surface-hairline px-4 py-4">
              <p class="eyebrow-label !tracking-[0.22em]">Primary audience</p>
              <p class="mt-2 text-sm leading-6 text-zinc-700">PMs who want ownership, not theater.</p>
            </div>
          </div>
        </div>
      </div>

      <aside class="surface-panel px-6 py-7 sm:px-8 sm:py-8">
        <div class="space-y-6">
          <div class="space-y-2">
            <p class="eyebrow-label">The board standard</p>
            <h2 class="text-3xl font-semibold leading-[0.96] tracking-[-0.055em] text-zinc-950">
              A product role should be legible before anyone applies.
            </h2>
          </div>

          <div class="space-y-4">
            {heroSignals.map((signal, index) => (
              <div class:list={["space-y-2", index > 0 && "keyline"]}>
                <p class="text-sm font-semibold tracking-[-0.03em] text-zinc-950">{signal.title}</p>
                <p class="text-sm leading-6 text-zinc-600">{signal.body}</p>
              </div>
            ))}
          </div>
        </div>
      </aside>
    </section>

    <section class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div class="space-y-5">
        <p class="eyebrow-label">Why this exists</p>
        <h2 class="section-title max-w-3xl">The title kept expanding. The mandate kept shrinking.</h2>
        <p class="lede-text max-w-3xl !text-[1.05rem] sm:!text-[1.15rem]">
          The market has blurred product management into a catch-all role near planning, delivery,
          or stakeholder coordination. The result is a lot of job descriptions that sound strategic
          but function like operational buffering.
        </p>
        <p class="body-copy max-w-2xl">
          That creates noise for everyone. Candidates cannot tell what the work really is.
          Employers publish vague roles and then wonder why the hiring loop misfires. This board
          exists to make scope visible before either side wastes time.
        </p>
      </div>

      <aside class="surface-panel px-6 py-7 sm:px-8 sm:py-8">
        <div class="space-y-4">
          <p class="eyebrow-label">What we do not list</p>
          <ul class="detail-list">
            {exclusions.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </aside>
    </section>

    <section class="space-y-8">
      <SectionIntro
        eyebrow="The three signals we filter for"
        headingTag="h2"
        title="Ownership, authority, and learning are the real line."
        description="Roadmaps, artifacts, and ceremony can show up in many adjacent roles. The actual distinction is whether the PM can own a result, make consequential decisions, and generate learning."
      />

      <div class="grid gap-4 lg:grid-cols-3">
        {heroSignals.map((signal, index) => (
          <article class="surface-panel px-6 py-7 sm:px-7">
            <div class="space-y-6">
              <div class="flex items-center justify-between gap-3">
                <p class="eyebrow-label">Signal 0{index + 1}</p>
                <span class="text-sm font-semibold tracking-[-0.03em] text-zinc-400">
                  0{index + 1}
                </span>
              </div>

              <div class="space-y-3">
                <h3 class="text-2xl font-semibold leading-[0.98] tracking-[-0.05em] text-zinc-950">
                  {signal.title}
                </h3>
                <p class="body-copy">{signal.body}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="space-y-8">
      <SectionIntro
        eyebrow="Featured jobs"
        headingTag="h2"
        title="A few current listings that fit the bar."
        description="These are still demo entries in the MVP, but the layout and evidence model mirror how the board should feel when real jobs replace them."
      >
        <div class="flex flex-wrap gap-2">
          <Pill label={`${featuredJobs.length} featured`} />
          <Pill label="Sample content" />
        </div>
      </SectionIntro>

      <div class="grid gap-4 lg:grid-cols-3">
        {featuredJobs.map((job) => (
          <article class="surface-panel px-6 py-7 sm:px-7">
            <div class="flex h-full flex-col gap-6">
              <div class="flex flex-wrap gap-2">
                <Pill label={job.data.contentStatus} />
                <Pill label={formatJobFilterValue("level", job.data.level)} />
              </div>

              <div class="space-y-3">
                <p class="text-sm font-medium text-zinc-500">{job.data.company}</p>
                <h3 class="text-[1.9rem] font-semibold leading-[0.98] tracking-[-0.05em] text-zinc-950">
                  {job.data.title}
                </h3>
                <p class="text-sm leading-6 text-zinc-600">{job.data.summary}</p>
              </div>

              <div class="grid gap-3 sm:grid-cols-2">
                <div class="surface-hairline px-4 py-4">
                  <p class="eyebrow-label !tracking-[0.22em]">Outcome signal</p>
                  <p class="mt-2 text-sm leading-6 text-zinc-700">{job.data.outcomesOwned[0]}</p>
                </div>
                <div class="surface-hairline px-4 py-4">
                  <p class="eyebrow-label !tracking-[0.22em]">Discovery signal</p>
                  <p class="mt-2 text-sm leading-6 text-zinc-700">{job.data.discoveryModel}</p>
                </div>
              </div>

              <div class="mt-auto flex items-center justify-between gap-3 keyline">
                <div class="text-sm text-zinc-500">
                  {job.data.location} · {formatJobFilterValue("remote", job.data.remote)}
                </div>
                <a class="button-secondary px-4 py-2.5" href={withBase(getJobDetailPath(job.data.slug))}>
                  View Sample Role
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <CtaBlock
      eyebrow="For employers"
      title="If you want stronger PM candidates, publish a role with actual scope."
      description="The best candidates are screening for the same things this board is screening for: what the PM owns, what the PM can decide, and how the PM is expected to learn."
      href="/for-employers"
      ctaLabel="For Employers"
    />

    <section class="surface-panel px-6 py-8 sm:px-8 sm:py-10 lg:px-10">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
        <div class="max-w-3xl space-y-4">
          <p class="eyebrow-label">Final cut</p>
          <h2 class="section-title max-w-3xl">
            The bar is simple: if the role does not own outcomes, decisions, and discovery, it does
            not go on the board.
          </h2>
          <p class="body-copy max-w-2xl">
            The point is not to look comprehensive. The point is to make real product scope easier
            to recognize.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="button-primary" href={jobsHref}>Browse Jobs</a>
          <a class="button-secondary" href={employersHref}>For Employers</a>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

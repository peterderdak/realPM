---
import MainLayout from "../layouts/MainLayout.astro";
import CtaBlock from "../components/CtaBlock.astro";
import Pill from "../components/Pill.astro";
import SectionIntro from "../components/SectionIntro.astro";
import { getFeaturedJobs } from "../data/jobs";
import { siteConfig, withBase } from "../data/site";

const featuredJobs = await getFeaturedJobs();
const jobsHref = withBase("/jobs");
const methodologyHref = withBase("/methodology");
const employersHref = withBase("/for-employers");

const primaryLinkClasses =
  "inline-flex items-center justify-center border border-stone-900 bg-stone-900 px-5 py-3 text-sm font-semibold text-stone-50 transition-colors duration-150 hover:bg-stone-700 hover:border-stone-700";
const secondaryLinkClasses =
  "inline-flex items-center justify-center border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-900 transition-colors duration-150 hover:border-stone-900";

const signals = [
  {
    title: "Outcome ownership",
    description:
      "The role owns a real result, not just a queue. We look for accountability tied to a product area, workflow, or problem space that can actually move.",
  },
  {
    title: "Decision rights",
    description:
      "The PM needs room to choose. That includes prioritization authority, sequencing judgment, and a visible say in what the team will not do.",
  },
  {
    title: "Discovery capacity",
    description:
      "The role needs time and permission to learn. If a PM is expected to ship without customer contact, evidence, or exploration, the title is doing too much work.",
  },
];

const exclusions = [
  {
    title: "delivery-buffer",
    description:
      "Roles that exist mainly to absorb requests, protect timelines, or keep a queue moving without owning the product problem.",
  },
  {
    title: "backlog-admin",
    description:
      "Roles centered on ticket grooming, status traffic, and coordination ritual, with little authority over what matters or why.",
  },
  {
    title: "stakeholder-proxy",
    description:
      "Roles that relay other people's priorities without enough mandate to define outcomes, make tradeoffs, or run discovery.",
  },
];

const formatLabel = (value: string) =>
  value
    .split("-")
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(" ");
---

<MainLayout
  title={siteConfig.name}
  description="Most PM jobs are not actually PM jobs. Real PM Jobs filters for outcome ownership, decision rights, and discovery capacity."
>
  <div class="space-y-24 sm:space-y-28">
    <section class="border-y border-stone-200 py-12 sm:py-16">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.55fr)_minmax(18rem,0.9fr)] lg:items-start">
        <div class="space-y-8">
          <Pill label="Editorial PM job board" />

          <div class="max-w-3xl space-y-6">
            <h1 class="font-serif text-5xl tracking-tight text-stone-950 sm:text-6xl">
              Most PM jobs aren&apos;t actually PM jobs.
            </h1>
            <p class="text-xl leading-8 text-stone-700 sm:text-2xl sm:leading-9">
              Real PM Jobs filters for roles with outcome ownership, decision rights, and discovery
              capacity. If the mandate is missing, the title does not make it a PM job.
            </p>
            <p class="max-w-2xl text-base leading-7 text-stone-600 sm:text-lg sm:leading-8">
              This is not a catch-all board for anything adjacent to product. It is a narrower
              publication for roles that still expect a PM to think clearly, make tradeoffs, and
              learn from the work.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a class={primaryLinkClasses} href={jobsHref}>Browse Jobs</a>
            <a class={secondaryLinkClasses} href={methodologyHref}>See Methodology</a>
          </div>
        </div>

        <aside class="border border-stone-200 bg-white px-6 py-6 sm:px-7">
          <div class="space-y-5">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500">
              What gets through
            </p>
            <div class="space-y-4">
              <div class="space-y-1">
                <p class="font-serif text-xl tracking-tight text-stone-950">Real outcome ownership</p>
                <p class="text-sm leading-6 text-stone-600">
                  Someone is clearly on the hook for a product result, not just the movement of work.
                </p>
              </div>
              <div class="space-y-1 border-t border-stone-200 pt-4">
                <p class="font-serif text-xl tracking-tight text-stone-950">Actual decision rights</p>
                <p class="text-sm leading-6 text-stone-600">
                  The role can set priorities, make tradeoffs, and define what the team will not do.
                </p>
              </div>
              <div class="space-y-1 border-t border-stone-200 pt-4">
                <p class="font-serif text-xl tracking-tight text-stone-950">Enough room for discovery</p>
                <p class="text-sm leading-6 text-stone-600">
                  The PM is expected to investigate the problem, not just administrate delivery.
                </p>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.9fr)]">
      <div class="max-w-3xl space-y-5">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500">Why this exists</p>
        <h2 class="font-serif text-4xl tracking-tight text-stone-950 sm:text-5xl">
          The PM title has drifted.
        </h2>
        <p class="text-lg leading-8 text-stone-700">
          Too many roles borrow the language of product management without the mandate. They sit
          near roadmap work, but the actual job is buffering delivery, maintaining a backlog, or
          translating requests between louder stakeholders.
        </p>
        <p class="text-base leading-7 text-stone-600">
          That hurts candidates and employers alike. Candidates cannot tell what the work really is.
          Employers end up hiring against a title instead of a responsibility set. This board exists
          to make that difference legible before anyone wastes time.
        </p>
      </div>

      <aside class="border border-stone-200 bg-white px-6 py-6 sm:px-7">
        <div class="space-y-5">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500">We do not list</p>
          <ul class="space-y-4">
            {exclusions.map((item, index) => (
              <li class:list={["space-y-1", index > 0 && "border-t border-stone-200 pt-4"]}>
                <p class="font-serif text-xl tracking-tight text-stone-950">{item.title}</p>
                <p class="text-sm leading-6 text-stone-600">{item.description}</p>
              </li>
            ))}
          </ul>
        </div>
      </aside>
    </section>

    <section class="space-y-8">
      <SectionIntro
        eyebrow="The three signals we filter for"
        headingTag="h2"
        title="A PM role should own outcomes, decisions, and learning."
        description="We are not looking for perfect job descriptions. We are looking for enough evidence that the role can function as actual product management."
      />

      <div class="grid gap-5 lg:grid-cols-3">
        {signals.map((signal) => (
          <article class="border border-stone-200 bg-white px-6 py-7 sm:px-7">
            <div class="space-y-4">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500">
                Signal
              </p>
              <h3 class="font-serif text-2xl tracking-tight text-stone-950">{signal.title}</h3>
              <p class="text-base leading-7 text-stone-700">{signal.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="space-y-8">
      <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
        <SectionIntro
          eyebrow="Featured jobs"
          headingTag="h2"
          title="Current featured roles"
          description="These featured listings are pulled directly from the job content collection. In the current MVP, they remain clearly labeled as sample content."
        />

        <div class="flex flex-wrap gap-3">
          <Pill label={`${featuredJobs.length} featured`} />
          <Pill label="Sample content only" />
        </div>
      </div>

      <div class="grid gap-5 lg:grid-cols-2">
        {featuredJobs.map((job) => (
          <article class="flex h-full flex-col border border-stone-200 bg-white px-6 py-7 sm:px-7">
            <div class="space-y-5">
              <div class="flex flex-wrap gap-2">
                <Pill label={job.data.contentStatus} />
                <Pill label={formatLabel(job.data.archetype)} />
                <Pill label={formatLabel(job.data.level)} />
              </div>

              <div class="space-y-2">
                <p class="text-sm font-medium text-stone-600">{job.data.company}</p>
                <h3 class="font-serif text-3xl tracking-tight text-stone-950">{job.data.title}</h3>
                <p class="text-base leading-7 text-stone-700">{job.data.summary}</p>
              </div>

              <dl class="grid gap-3 text-sm text-stone-700 sm:grid-cols-3">
                <div>
                  <dt class="font-semibold text-stone-950">Location</dt>
                  <dd>{job.data.location}</dd>
                </div>
                <div>
                  <dt class="font-semibold text-stone-950">Remote</dt>
                  <dd class="capitalize">{job.data.remote}</dd>
                </div>
                <div>
                  <dt class="font-semibold text-stone-950">Stage</dt>
                  <dd>{formatLabel(job.data.stage)}</dd>
                </div>
              </dl>
            </div>

            <div class="mt-6 grid gap-5 border-t border-stone-200 pt-5">
              <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500">
                  Outcome ownership
                </p>
                <p class="text-sm leading-6 text-stone-700">{job.data.outcomesOwned[0]}</p>
              </div>
              <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500">
                  Decision rights
                </p>
                <p class="text-sm leading-6 text-stone-700">{job.data.decisionRights[0]}</p>
              </div>
              <div class="space-y-2">
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500">
                  Discovery capacity
                </p>
                <p class="text-sm leading-6 text-stone-700">{job.data.discoveryModel}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <CtaBlock
      eyebrow="For employers"
      title="If you want strong PM candidates, publish a role with real scope."
      description="Write the mandate clearly. Show what outcomes the PM owns, what decisions they can make, and how they are expected to learn. That is what attracts the right people."
      href="/for-employers"
      ctaLabel="For Employers"
    />

    <section class="border-t border-stone-200 pt-10 sm:pt-12">
      <div class="border border-stone-200 bg-white px-6 py-8 sm:px-8 sm:py-10">
        <div class="flex flex-col gap-8 md:flex-row md:items-end md:justify-between">
          <div class="max-w-3xl space-y-4">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-stone-500">
              Final cut
            </p>
            <h2 class="font-serif text-3xl tracking-tight text-stone-950 sm:text-4xl">
              If the role does not own outcomes, decision rights, and discovery capacity, it does
              not go on the board.
            </h2>
            <p class="text-base leading-7 text-stone-700">
              The standard is the product. The job board is just the delivery mechanism.
            </p>
          </div>

          <div class="flex flex-wrap gap-3">
            <a class={primaryLinkClasses} href={jobsHref}>Browse Jobs</a>
            <a class={secondaryLinkClasses} href={methodologyHref}>See Methodology</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

---
import JobCard from "../components/JobCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
import Pill from "../components/Pill.astro";
import { getAllPublishedJobs, getJobFilterOptions } from "../data/jobs";

const jobs = await getAllPublishedJobs();
const filterOptions = getJobFilterOptions(jobs);
---

<MainLayout
  title="Jobs"
  description="Browse all non-draft roles on Real PM Jobs. The board stays visible without JavaScript, with lightweight client-side filters when available."
>
  <div class="space-y-12 sm:space-y-14">
    <section class="grid gap-5 xl:grid-cols-[minmax(0,1.08fr)_minmax(0,0.92fr)]">
      <div class="panel-dark px-6 py-8 sm:px-8 sm:py-10 lg:px-10">
        <div class="max-w-4xl space-y-7">
          <div class="flex flex-wrap gap-2">
            <Pill label={`${jobs.length} published roles`} />
            <Pill label="Drafts excluded" />
          </div>

          <div class="space-y-4">
            <p class="eyebrow-label text-zinc-400">Board index</p>
            <h1 class="display-title max-w-4xl text-white">A smaller board with a sharper bar.</h1>
            <p class="max-w-3xl text-[1.06rem] leading-8 text-zinc-300 sm:text-[1.24rem] sm:leading-9">
              Every non-draft role appears here by default. Filters narrow the board in-browser when
              JavaScript is available, but the full list remains readable without it.
            </p>
          </div>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-1">
        <div class="panel px-6 py-6 sm:px-7">
          <p class="eyebrow-label">Visible now</p>
          <p class="mt-3 text-5xl font-semibold tracking-[-0.08em] text-zinc-950" aria-live="polite">
            <span data-visible-count>{jobs.length}</span>
          </p>
          <p class="mt-3 text-sm leading-6 text-zinc-600">Roles currently on screen after filtering.</p>
        </div>

        <div class="panel px-6 py-6 sm:px-7">
          <p class="eyebrow-label">Board logic</p>
          <p class="mt-3 text-sm leading-6 text-zinc-600">
            This board is sorted by editorial relevance and review freshness, not by volume,
            velocity, or marketplace tricks.
          </p>
        </div>
      </div>
    </section>

    <section class="panel px-6 py-6 sm:px-8 sm:py-8">
      <div class="space-y-6">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
          <div class="max-w-3xl space-y-2">
            <p class="eyebrow-label">Filters</p>
            <p class="body-copy">
              Filter by archetype, level, stage, or remote model. The experience enhances in the
              browser, but the baseline remains a complete static board.
            </p>
          </div>

          <div class="flex flex-wrap gap-2">
            <Pill label="Archetype" />
            <Pill label="Level" />
            <Pill label="Stage" />
            <Pill label="Remote" />
          </div>
        </div>

        <form class="grid gap-4 sm:grid-cols-2 xl:grid-cols-[repeat(4,minmax(0,1fr))_auto]" data-jobs-filters>
          <label class="grid gap-2">
            <span class="eyebrow-label !tracking-[0.22em]">Archetype</span>
            <select
              class="rounded-[1.25rem] border border-black/10 bg-white/80 px-4 py-3 text-sm text-zinc-900 shadow-sm backdrop-blur-sm"
              data-filter="archetype"
              name="archetype"
            >
              <option value="">All archetypes</option>
              {filterOptions.archetype.map((option) => (
                <option value={option.value}>{option.label} ({option.count})</option>
              ))}
            </select>
          </label>

          <label class="grid gap-2">
            <span class="eyebrow-label !tracking-[0.22em]">Level</span>
            <select
              class="rounded-[1.25rem] border border-black/10 bg-white/80 px-4 py-3 text-sm text-zinc-900 shadow-sm backdrop-blur-sm"
              data-filter="level"
              name="level"
            >
              <option value="">All levels</option>
              {filterOptions.level.map((option) => (
                <option value={option.value}>{option.label} ({option.count})</option>
              ))}
            </select>
          </label>

          <label class="grid gap-2">
            <span class="eyebrow-label !tracking-[0.22em]">Stage</span>
            <select
              class="rounded-[1.25rem] border border-black/10 bg-white/80 px-4 py-3 text-sm text-zinc-900 shadow-sm backdrop-blur-sm"
              data-filter="stage"
              name="stage"
            >
              <option value="">All stages</option>
              {filterOptions.stage.map((option) => (
                <option value={option.value}>{option.label} ({option.count})</option>
              ))}
            </select>
          </label>

          <label class="grid gap-2">
            <span class="eyebrow-label !tracking-[0.22em]">Remote</span>
            <select
              class="rounded-[1.25rem] border border-black/10 bg-white/80 px-4 py-3 text-sm text-zinc-900 shadow-sm backdrop-blur-sm"
              data-filter="remote"
              name="remote"
            >
              <option value="">All remote models</option>
              {filterOptions.remote.map((option) => (
                <option value={option.value}>{option.label} ({option.count})</option>
              ))}
            </select>
          </label>

          <div class="flex items-end">
            <button class="button-secondary w-full xl:w-auto" type="reset">Clear Filters</button>
          </div>
        </form>

        <noscript>
          <p class="text-sm leading-6 text-zinc-600">
            JavaScript is disabled, so filters are not interactive. The full board is shown below.
          </p>
        </noscript>
      </div>
    </section>

    <section class="space-y-6">
      <div class="panel-muted px-6 py-6 text-sm leading-6 text-zinc-700" data-empty-state hidden>
        No roles match the current filters. Clear one or more filters to return to the full board.
      </div>

      <ul class="space-y-5" data-jobs-list>
        {jobs.map((job) => (
          <li
            data-archetype={job.data.archetype}
            data-job-card
            data-level={job.data.level}
            data-remote={job.data.remote}
            data-stage={job.data.stage}
          >
            <JobCard job={job} />
          </li>
        ))}
      </ul>
    </section>
  </div>
</MainLayout>

<script>
  import { jobFilterKeys, matchesJobFilters } from "../utils/job-filters.js";

  const filterForm = document.querySelector<HTMLFormElement>("[data-jobs-filters]");
  const visibleCountElement = document.querySelector<HTMLElement>("[data-visible-count]");
  const emptyState = document.querySelector<HTMLElement>("[data-empty-state]");
  const jobCards = Array.from(document.querySelectorAll<HTMLElement>("[data-job-card]"));

  if (filterForm && visibleCountElement && emptyState && jobCards.length > 0) {
    const getFilters = () =>
      Object.fromEntries(
        jobFilterKeys.map((key) => {
          const input = filterForm.querySelector<HTMLSelectElement>(`[data-filter="${key}"]`);

          return [key, input?.value ?? ""];
        }),
      );

    const updateVisibleJobs = () => {
      const filters = getFilters();
      let visibleJobs = 0;

      jobCards.forEach((card) => {
        const job = {
          archetype: card.dataset.archetype ?? "",
          level: card.dataset.level ?? "",
          stage: card.dataset.stage ?? "",
          remote: card.dataset.remote ?? "",
        };
        const isVisible = matchesJobFilters(job, filters);

        card.hidden = !isVisible;

        if (isVisible) {
          visibleJobs += 1;
        }
      });

      visibleCountElement.textContent = String(visibleJobs);
      emptyState.hidden = visibleJobs !== 0;
    };

    filterForm.addEventListener("change", updateVisibleJobs);
    filterForm.addEventListener("reset", () => {
      window.requestAnimationFrame(updateVisibleJobs);
    });

    updateVisibleJobs();
  }
</script>

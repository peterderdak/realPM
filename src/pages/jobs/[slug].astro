---
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import Pill from "../../components/Pill.astro";
import MainLayout from "../../layouts/MainLayout.astro";
import {
  formatJobFilterValue,
  formatReviewedDate,
  getAllPublishedJobs,
  getJobDetailPath,
} from "../../data/jobs";
import { withBase } from "../../data/site";

type JobEntry = CollectionEntry<"jobs">;

export const getStaticPaths: GetStaticPaths = async () => {
  const jobs = await getAllPublishedJobs();

  return jobs.map((job) => ({
    params: { slug: job.data.slug },
    props: {
      job,
      relatedJobs: (() => {
        const sameArchetype = jobs.filter(
          (candidate) =>
            candidate.id !== job.id && candidate.data.archetype === job.data.archetype,
        );
        const sameStage = jobs.filter(
          (candidate) =>
            candidate.id !== job.id &&
            candidate.data.stage === job.data.stage &&
            !sameArchetype.some((related) => related.id === candidate.id),
        );

        return [...sameArchetype, ...sameStage].slice(0, 3);
      })(),
    },
  }));
};

const { job, relatedJobs } = Astro.props as { job: JobEntry; relatedJobs: JobEntry[] };
const jobsHref = withBase("/jobs");
const applyHref = job.data.applyUrl;
const methodologyHref = withBase("/methodology");

const evidenceSections = [
  {
    title: "Outcomes owned",
    items: job.data.outcomesOwned,
  },
  {
    title: "Decision rights",
    items: job.data.decisionRights,
  },
  {
    title: "Unknowns",
    items:
      job.data.unknowns.length > 0
        ? job.data.unknowns
        : ["No open unknowns are recorded for this entry yet."],
  },
];
---

<MainLayout title={job.data.title} description={job.data.summary}>
  <div class="space-y-10 sm:space-y-12">
    <a class="button-ghost -ml-4 px-4" href={jobsHref}>Back to Jobs</a>

    <section class="grid gap-5 xl:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)]">
      <div class="panel-dark px-6 py-8 sm:px-8 sm:py-10 lg:px-10">
        <div class="max-w-4xl space-y-7">
          <div class="flex flex-wrap gap-2">
            <Pill label={job.data.contentStatus} />
            {job.data.featured && <Pill label="Featured" />}
            <Pill label={formatJobFilterValue("archetype", job.data.archetype)} />
            <Pill label={formatJobFilterValue("level", job.data.level)} />
          </div>

          <div class="space-y-4">
            <p class="eyebrow-label text-zinc-400">Role detail</p>
            <p class="text-sm font-medium text-zinc-400">{job.data.company}</p>
            <h1 class="display-title max-w-4xl text-white">{job.data.title}</h1>
            <p class="max-w-3xl text-[1.06rem] leading-8 text-zinc-300 sm:text-[1.22rem] sm:leading-9">
              {job.data.summary}
            </p>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-5">
            <div class="metric-card">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.26em] text-zinc-400">
                Location
              </p>
              <p class="mt-3 text-sm leading-6 text-zinc-100">{job.data.location}</p>
            </div>
            <div class="metric-card">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.26em] text-zinc-400">
                Remote
              </p>
              <p class="mt-3 text-sm leading-6 text-zinc-100">
                {formatJobFilterValue("remote", job.data.remote)}
              </p>
            </div>
            <div class="metric-card">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.26em] text-zinc-400">
                Level
              </p>
              <p class="mt-3 text-sm leading-6 text-zinc-100">
                {formatJobFilterValue("level", job.data.level)}
              </p>
            </div>
            <div class="metric-card">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.26em] text-zinc-400">
                Archetype
              </p>
              <p class="mt-3 text-sm leading-6 text-zinc-100">
                {formatJobFilterValue("archetype", job.data.archetype)}
              </p>
            </div>
            <div class="metric-card">
              <p class="text-[0.72rem] font-semibold uppercase tracking-[0.26em] text-zinc-400">
                Stage
              </p>
              <p class="mt-3 text-sm leading-6 text-zinc-100">
                {formatJobFilterValue("stage", job.data.stage)}
              </p>
            </div>
          </div>
        </div>
      </div>

      <aside class="space-y-4 xl:sticky xl:top-28 xl:self-start">
        <div class="panel px-6 py-6 sm:px-7">
          <div class="space-y-5">
            <div class="space-y-2">
              <p class="eyebrow-label">Apply</p>
              <p class="text-sm leading-6 text-zinc-600">
                Open the original listing. This board curates for scope, not title alone.
              </p>
            </div>
            <a class="button-primary w-full" href={applyHref} rel="noreferrer" target="_blank">
              Open Apply Link
            </a>
          </div>
        </div>

        <div class="panel px-6 py-6 sm:px-7">
          <div class="space-y-5">
            <div class="space-y-2">
              <p class="eyebrow-label">Review status</p>
              <p class="text-sm leading-6 text-zinc-700">
                Reviewed {formatReviewedDate(job.data.reviewedAt)} with{" "}
                {formatJobFilterValue("confidence", job.data.confidence).toLowerCase()} confidence.
              </p>
            </div>

            <div class="keyline space-y-2">
              <p class="eyebrow-label">Methodology note</p>
              <p class="text-sm leading-6 text-zinc-600">
                Listings stay on the board only while the available evidence suggests meaningful PM
                scope.
              </p>
              <a class="button-secondary w-full" href={methodologyHref}>Read Methodology</a>
            </div>
          </div>
        </div>
      </aside>
    </section>

    <section class="grid gap-5 xl:grid-cols-[minmax(0,0.86fr)_minmax(0,1.14fr)]">
      <section class="panel px-6 py-7 sm:px-8 sm:py-8">
        <div class="space-y-4">
          <p class="eyebrow-label">Why it made the board</p>
          <ul class="detail-list">
            {job.data.whyItMadeBoard.map((reason) => (
              <li>{reason}</li>
            ))}
          </ul>
        </div>
      </section>

      <section class="panel px-6 py-7 sm:px-8 sm:py-8">
        <div class="space-y-5">
          <div class="space-y-3">
            <p class="eyebrow-label">Evidence pack</p>
            <h2 class="section-title !text-[2.2rem] sm:!text-[2.9rem]">
              The signals behind the listing.
            </h2>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            {evidenceSections.map((section) => (
              <section class="surface-hairline px-5 py-5">
                <div class="space-y-4">
                  <h3 class="text-[1.45rem] font-semibold leading-[0.96] tracking-[-0.06em] text-zinc-950">
                    {section.title}
                  </h3>
                  <ul class="detail-list">
                    {section.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              </section>
            ))}

            <section class="surface-hairline px-5 py-5">
              <div class="space-y-4">
                <h3 class="text-[1.45rem] font-semibold leading-[0.96] tracking-[-0.06em] text-zinc-950">
                  Discovery model
                </h3>
                <p class="text-sm leading-6 text-zinc-700">{job.data.discoveryModel}</p>
              </div>
            </section>

            <section class="surface-hairline px-5 py-5">
              <div class="space-y-4">
                <h3 class="text-[1.45rem] font-semibold leading-[0.96] tracking-[-0.06em] text-zinc-950">
                  Team topology
                </h3>
                <p class="text-sm leading-6 text-zinc-700">{job.data.teamTopology}</p>
              </div>
            </section>

            <section class="surface-hairline px-5 py-5 md:col-span-2">
              <div class="space-y-4">
                <h3 class="text-[1.45rem] font-semibold leading-[0.96] tracking-[-0.06em] text-zinc-950">
                  Strategy scope
                </h3>
                <p class="text-sm leading-6 text-zinc-700">{job.data.strategyScope}</p>
              </div>
            </section>
          </div>
        </div>
      </section>
    </section>

    {relatedJobs.length > 0 && (
      <section class="space-y-6">
        <div class="space-y-3">
          <p class="eyebrow-label">Related roles</p>
          <h2 class="section-title max-w-3xl">More jobs with adjacent scope.</h2>
          <p class="body-copy max-w-2xl">
            Related roles are chosen by shared archetype first, then by shared stage.
          </p>
        </div>

        <div class="grid gap-4 lg:grid-cols-3">
          {relatedJobs.map((relatedJob) => (
            <article class="panel px-6 py-6 sm:px-7">
              <div class="space-y-5">
                <div class="flex flex-wrap gap-2">
                  <Pill label={formatJobFilterValue("archetype", relatedJob.data.archetype)} />
                  <Pill label={formatJobFilterValue("stage", relatedJob.data.stage)} />
                </div>

                <div class="space-y-3">
                  <p class="text-sm font-medium text-zinc-500">{relatedJob.data.company}</p>
                  <h3 class="text-[1.7rem] font-semibold leading-[0.96] tracking-[-0.07em] text-zinc-950">
                    <a
                      class="transition-colors duration-150 hover:text-zinc-700"
                      href={withBase(getJobDetailPath(relatedJob.data.slug))}
                    >
                      {relatedJob.data.title}
                    </a>
                  </h3>
                  <p class="text-sm leading-6 text-zinc-600">{relatedJob.data.summary}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </div>
</MainLayout>

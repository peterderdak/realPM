---
import MainLayout from "../layouts/MainLayout.astro";
import Pill from "../components/Pill.astro";
import { withBase } from "../data/site";

const homeHref = withBase("/");
const jobsHref = withBase("/jobs");
const methodologyHref = withBase("/methodology");
---

<MainLayout
  title="Page Not Found"
  description="The page you requested could not be found on Real PM Jobs."
  noIndex={true}
>
  <div class="space-y-10">
    <section class="surface-panel-soft px-6 py-8 sm:px-8 sm:py-10 lg:px-10">
      <div class="max-w-3xl space-y-6">
        <div class="flex flex-wrap gap-2">
          <Pill label="404" />
          <Pill label="Not found" />
        </div>

        <div class="space-y-4">
          <p class="eyebrow-label">Missing page</p>
          <h1 class="display-title max-w-3xl !text-[3.4rem] sm:!text-[4.4rem]">
            That page is not here.
          </h1>
          <p class="lede-text max-w-2xl !text-[1.05rem] sm:!text-[1.15rem]">
            The link may be outdated, the URL may be wrong, or the page may have been removed after
            review. Use the board and methodology pages to keep moving.
          </p>
        </div>
      </div>
    </section>

    <section class="flex flex-wrap gap-3">
      <a class="button-primary" href={jobsHref}>Browse Jobs</a>
      <a class="button-secondary" href={methodologyHref}>Read Methodology</a>
      <a class="button-secondary" href={homeHref}>Go Home</a>
    </section>
  </div>
</MainLayout>

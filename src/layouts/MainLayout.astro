---
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Container from "../components/Container.astro";
import { siteConfig, withBase } from "../data/site";

interface Props {
  title: string;
  description?: string;
  noIndex?: boolean;
}

const {
  title,
  description = siteConfig.description,
  noIndex = false,
} = Astro.props;
const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const socialImageUrl = Astro.site
  ? new URL(withBase(siteConfig.socialImagePath), Astro.site).toString()
  : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
    <meta name="theme-color" content="#f8f7f3" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {noIndex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
    {socialImageUrl && <meta property="og:image:alt" content={`${siteConfig.name} social card`} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
    <title>{pageTitle}</title>
  </head>
  <body class="min-h-screen text-zinc-950 antialiased">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="relative isolate flex min-h-screen flex-col overflow-x-hidden">
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-[28rem] bg-[radial-gradient(circle_at_top,rgba(160,194,247,0.18),transparent_40%),radial-gradient(circle_at_22%_18%,rgba(255,255,255,0.78),transparent_20%)]"
      >
      </div>
      <Header />
      <main id="main-content" class="flex-1 pb-20 pt-10 sm:pb-24 sm:pt-14">
        <Container>
          <slot />
        </Container>
      </main>
      <Footer />
    </div>
  </body>
</html>
